; Resolved production example — ASTERISK_EXTERNAL_IP=13.62.237.148
; AOR section id is 1001@IP (not [1001] type=aor — that collides with [1001] type=endpoint in INI parser)

[global]
type=global
endpoint_identifier_order=auth_username,username
default_realm=13.62.237.148

[transport-wss]
type=transport
protocol=ws
bind=0.0.0.0:8089
external_signaling_address=13.62.237.148
external_media_address=13.62.237.148

[1001-auth]
type=auth
auth_type=userpass
username=1001
password=1001
realm=13.62.237.148

[1001@13.62.237.148]
type=aor
max_contacts=5
remove_existing=yes
support_path=yes
qualify_frequency=30

[1001]
type=endpoint
transport=transport-wss
context=internal
aors=1001@13.62.237.148
auth=1001-auth
from_user=1001
from_domain=13.62.237.148
disallow=all
allow=opus,ulaw,alaw
webrtc=yes
force_rport=yes
rewrite_contact=yes
rtp_symmetric=yes
direct_media=no
identify_by=username,auth_username
dtls_auto_generate_cert=yes
dtls_verify=fingerprint
dtls_setup=actpass
ice_support=yes
media_use_received_transport=yes
rtcp_mux=yes

[1002-auth]
type=auth
auth_type=userpass
username=1002
password=1002
realm=13.62.237.148

[1002@13.62.237.148]
type=aor
max_contacts=5
remove_existing=yes
support_path=yes
qualify_frequency=30

[1002]
type=endpoint
transport=transport-wss
context=internal
aors=1002@13.62.237.148
auth=1002-auth
from_user=1002
from_domain=13.62.237.148
disallow=all
allow=opus,ulaw,alaw
webrtc=yes
force_rport=yes
rewrite_contact=yes
rtp_symmetric=yes
direct_media=no
identify_by=username,auth_username
dtls_auto_generate_cert=yes
dtls_verify=fingerprint
dtls_setup=actpass
ice_support=yes
media_use_received_transport=yes
rtcp_mux=yes
