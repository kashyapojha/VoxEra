# ── Copy to .env.local for local dev (never commit .env.local) ───────
# Local:  npm run dev  OR  docker compose --env-file .env.local up --build
# Prod:   npm run build uses .env.production (or GitHub Secrets in CI)

# ── Shared ─────────────────────────────────────────────────────────
PUBLIC_HOST=localhost
ASTERISK_EXTERNAL_IP=127.0.0.1

# ── Frontend SIP (Vite — prefixed with VITE_) ──────────────────────
# Leave VITE_API_URL empty in production (nginx same-origin /api)
VITE_API_URL=http://localhost:5000
# Must match ASTERISK_EXTERNAL_IP (same host in URI, WebSocket, and digest realm)
VITE_SIP_WS_URL=ws://127.0.0.1:8089/ws
VITE_SIP_URI=sip:1001@127.0.0.1
VITE_SIP_PASSWORD=1001

# Production EC2 (.env.production + GitHub Secrets — baked into frontend at build):
# ASTERISK_EXTERNAL_IP=13.62.237.148
# VITE_SIP_WS_URL=ws://13.62.237.148:8089/ws
# VITE_SIP_URI=sip:1001@13.62.237.148
# VITE_SIP_PASSWORD=1001

# ── Backend ────────────────────────────────────────────────────────
PORT=5000
JWT_SECRET=change-me-in-production
ASTERISK_HOST=asterisk
ASTERISK_PORT=8089
ASTERISK_WSS_PORT=8089

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_DB=voxera
POSTGRES_USER=voxera
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgres://voxera:change-me-in-production@postgres:5432/voxera

# ── Docker Hub (GitHub Secrets for CI) ─────────────────────────────
# DOCKER_USERNAME=your-dockerhub-user
# DOCKERHUB_TOKEN=your-dockerhub-access-token
# Optional Variables: DOCKER_FRONTEND_REPO=voxera-frontend, DOCKER_BACKEND_REPO=voxera-backend
